# Copy this file to .env and fill in TUNNEL_TOKEN before `docker compose up`.
#
# Get TUNNEL_TOKEN by running, on the host (needs `cloudflared` installed
# locally, or use the Cloudflare Zero Trust dashboard instead):
#   cloudflared tunnel create kartradar
#   cloudflared tunnel route dns kartradar kartradar.<your-domain>
#   cloudflared tunnel token kartradar     <- prints the token
TUNNEL_TOKEN=

# Optional overrides — defaults shown
# Hour of day (0-23, local time) for the once-daily rediscovery + availability check.
DAILY_REFRESH_HOUR=0
DAYS_AHEAD=28
